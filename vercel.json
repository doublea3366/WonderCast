{
  "functions": {
    "api/tts.js": { "maxDuration": 60 },
    "api/generate.js": { "maxDuration": 30 },
    "api/check-topic.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/how-it-works", "destination": "/index.html" },
    { "source": "/for-families", "destination": "/index.html" },
    { "source": "/faq", "destination": "/index.html" },
    { "source": "/library", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
